{
  "name": "aethos-ps",
  "version": "0.1.0",
  "engines": {
    "node": "^20.11.1",
    "npm": ">=10"
  },
  "scripts": {
    "start": "ng serve --port 4201",
    "build": "ng build",
    "build:all": "ng build aethos-ps --configuration production && ng build timesheet --configuration production",
    "test": "ng test",
    "test:ci": "ng test --watch=false --browsers=ChromeHeadless",
    "typecheck": "tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.spec.json --noEmit && tsc -p projects/timesheet/tsconfig.app.json --noEmit",
    "lint": "ng lint",
    "e2e": "playwright test"
  },
  "dependencies": {
    "@angular/animations": "^20.3.26",
    "@angular/cdk": "^20.2.14",
    "@angular/common": "^20.3.26",
    "@angular/compiler": "^20.3.26",
    "@angular/core": "^20.3.26",
    "@angular/forms": "^20.3.26",
    "@angular/material": "^20.2.14",
    "@angular/platform-browser": "^20.3.26",
    "@angular/platform-browser-dynamic": "^20.3.26",
    "@angular/router": "^20.3.26",
    "@stripe/stripe-js": "^9.6.0",
    "@supabase/supabase-js": "^2.106.1",
    "rxjs": "^7.8.0",
    "tslib": "^2.6.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^20.3.32",
    "@angular/cli": "^20.3.32",
    "@angular/compiler-cli": "^20.3.26",
    "@playwright/test": "^1.44.0",
    "@types/jasmine": "~5.1.0",
    "@types/node": "^20.0.0",
    "@types/ws": "8.18.1",
    "autoprefixer": "^10.4.0",
    "jasmine-core": "~5.1.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "~5.9.3",
    "ws": "8.18.3"
  }
}
