SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_JWT_SECRET=your-jwt-secret
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Stripe Connect Standard — get from Stripe Dashboard > Connect > Settings
STRIPE_CONNECT_CLIENT_ID=ca_REPLACE_ME

# Stripe Price IDs — create these in the Stripe Dashboard (Products → Prices).
# One Price per plan × billing interval × currency (3 tiers × 2 intervals × 5 currencies = 30).
# See docs/PLAN.md §8.6 for suggested amounts.
#
# Starter — $29/£25/S$39/₹2,499/A$45 per month
STRIPE_PRICE_STARTER_MONTHLY_USD=price_...
STRIPE_PRICE_STARTER_MONTHLY_GBP=price_...
STRIPE_PRICE_STARTER_MONTHLY_SGD=price_...
STRIPE_PRICE_STARTER_MONTHLY_INR=price_...
STRIPE_PRICE_STARTER_MONTHLY_AUD=price_...
STRIPE_PRICE_STARTER_ANNUAL_USD=price_...
STRIPE_PRICE_STARTER_ANNUAL_GBP=price_...
STRIPE_PRICE_STARTER_ANNUAL_SGD=price_...
STRIPE_PRICE_STARTER_ANNUAL_INR=price_...
STRIPE_PRICE_STARTER_ANNUAL_AUD=price_...

# Growth — $79/£69/S$109/₹6,999/A$119 per month
STRIPE_PRICE_GROWTH_MONTHLY_USD=price_...
STRIPE_PRICE_GROWTH_MONTHLY_GBP=price_...
STRIPE_PRICE_GROWTH_MONTHLY_SGD=price_...
STRIPE_PRICE_GROWTH_MONTHLY_INR=price_...
STRIPE_PRICE_GROWTH_MONTHLY_AUD=price_...
STRIPE_PRICE_GROWTH_ANNUAL_USD=price_...
STRIPE_PRICE_GROWTH_ANNUAL_GBP=price_...
STRIPE_PRICE_GROWTH_ANNUAL_SGD=price_...
STRIPE_PRICE_GROWTH_ANNUAL_INR=price_...
STRIPE_PRICE_GROWTH_ANNUAL_AUD=price_...

# Pro — $199/£179/S$279/₹17,999/A$299 per month
STRIPE_PRICE_PRO_MONTHLY_USD=price_...
STRIPE_PRICE_PRO_MONTHLY_GBP=price_...
STRIPE_PRICE_PRO_MONTHLY_SGD=price_...
STRIPE_PRICE_PRO_MONTHLY_INR=price_...
STRIPE_PRICE_PRO_MONTHLY_AUD=price_...
STRIPE_PRICE_PRO_ANNUAL_USD=price_...
STRIPE_PRICE_PRO_ANNUAL_GBP=price_...
STRIPE_PRICE_PRO_ANNUAL_SGD=price_...
STRIPE_PRICE_PRO_ANNUAL_INR=price_...
STRIPE_PRICE_PRO_ANNUAL_AUD=price_...

# Frontend base URL (used for billing portal return_url)
FRONTEND_BASE_URL=http://localhost:4201
# LLM provider — OpenRouter (OpenAI-compatible). Used by all extraction + copilot agents.
OPENROUTER_API_KEY=sk-or-v1-...
# Ordered fallback chain — OpenRouter tries the first, falls back on error/rate-limit.
# Accepts either JSON list or comma-separated string (shell-source friendly).
AGENT_MODELS=google/gemma-4-31b-it:free,google/gemma-4-26b-a4b-it:free,anthropic/claude-haiku-4.5
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# Task queue (Procrastinate on Postgres / Supabase). Use the SESSION pooler
# (port 5432), NOT the transaction pooler (6543) — Procrastinate uses
# LISTEN/NOTIFY which is only supported on direct or session-pooled connections.
# Get from Supabase Dashboard → Project Settings → Database → Connection string
# → "Session pooler" → copy and paste here with your DB password.
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
# Set true in deployments where scheduled Procrastinate workers are required
# for readiness; async document extraction also makes the queue required.
QUEUE_REQUIRED=false
# Legacy — kept in env loader for backward compat. Unused since the
# ARQ → Procrastinate migration.
UPSTASH_REDIS_URL=
OPENEXCHANGERATES_APP_ID=  # optional — free tier (open.er-api.com) works without it
RESEND_API_KEY=re_REPLACE_ME
DEBUG=false
ENVIRONMENT=development
CORS_ORIGINS=["http://localhost:4201"]
